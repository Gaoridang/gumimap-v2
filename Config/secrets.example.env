# Copy to secrets.local.env and fill in real values
KAKAO_NATIVE_APP_KEY=your_kakao_native_app_key
KAKAO_REST_API_KEY=your_kakao_rest_api_key
XAI_API_KEY=your_xai_api_key

# App Store Connect API (local TestFlight only; CI uses GitHub secrets)
ASC_KEY_ID=your_asc_key_id
ASC_ISSUER_ID=your_asc_issuer_id
ASC_KEY_PATH=/path/to/AuthKey_XXXXX.p8