require "fileutils"
require "securerandom"
require_relative "lib/signing_decision"
require_relative "lib/project_marketing_version"

default_platform(:ios)

XCODEPROJ = File.expand_path("../gumimap-v2.xcodeproj", __dir__)
APP_TARGET = "gumimap-v2"
SIGNING_CACHE_DIR = File.expand_path("signing", __dir__)
BUNDLE_IDENTIFIER = "com.ijaejun.gumimap-v2"
TEAM_ID = "T5CBR768BM"

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  private_lane :asc_api_key do
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
      duration: 1200,
      in_house: false
    )
  end

  private_lane :prepare_app_secrets do
    sh("cd .. && ./scripts/generate-secrets.sh")
  end

  private_lane :apply_manual_signing do |options|
    profile_name = options.fetch(:profile_name)
    update_code_signing_settings(
      use_automatic_signing: false,
      path: XCODEPROJ,
      targets: ["gumimap-v2"],
      team_id: TEAM_ID,
      bundle_identifier: BUNDLE_IDENTIFIER,
      profile_name: profile_name,
      code_sign_identity: "Apple Distribution"
    )
  end

  private_lane :ci_keychain_credentials do
    path = Actions.lane_context[SharedValues::KEYCHAIN_PATH]
    if path.to_s.empty?
      keychain_name = ENV["MATCH_KEYCHAIN_NAME"] || "fastlane_tmp_keychain"
      path = File.expand_path("~/Library/Keychains/#{keychain_name}")
    end
    password = ENV["MATCH_KEYCHAIN_PASSWORD"]
    password = ENV["KEYCHAIN_PASSWORD"] if password.nil?
    password = "" if password.nil?
    UI.user_error!("CI keychain is not configured. setup_ci must run before signing.") if path.to_s.empty?

    expanded = File.expand_path(path)
    expanded = "#{expanded}-db" unless expanded.end_with?("-db") || File.exist?(expanded)
    [expanded, password]
  end

  private_lane :signing_cache_password do
    pass_file = File.join(SIGNING_CACHE_DIR, ".p12-pass")
    if File.exist?(pass_file)
      File.read(pass_file).strip
    else
      FileUtils.mkdir_p(SIGNING_CACHE_DIR)
      password = SecureRandom.hex(16)
      File.write(pass_file, password)
      password
    end
  end

  private_lane :import_cached_distribution_p12 do |options|
    p12_path = options.fetch(:p12_path)
    p12_password = options.fetch(:p12_password)
    keychain_path = options.fetch(:keychain_path)
    keychain_password = options.fetch(:keychain_password)

    sh(
      "security", "import", p12_path,
      "-P", p12_password,
      "-A", "-t", "cert", "-f", "pkcs12",
      "-k", keychain_path
    )
    sh(
      "security", "set-key-partition-list",
      "-S", "apple-tool:,apple:,codesign:",
      "-s", "-k", keychain_password, keychain_path
    )
  end

  private_lane :export_distribution_p12 do |options|
    output_path = options.fetch(:output_path)
    password = options.fetch(:password)
    keychain_path = options.fetch(:keychain_path)

    identity_line = sh(
      "security", "find-identity", "-v", "-p", "codesigning", keychain_path
    ).lines.find { |line| line.include?("Apple Distribution") }

    UI.user_error!("No Apple Distribution identity found in CI keychain") if identity_line.nil?

    # macOS security export on GitHub runners does not support -c (cert hash).
    # The CI keychain only contains the one Distribution identity we just installed.
    sh(
      "security", "export",
      "-k", keychain_path,
      "-t", "identities",
      "-f", "pkcs12",
      "-o", output_path,
      "-P", password
    )
  end

  private_lane :distribution_identity_in_keychain do |options|
    keychain_path = options.fetch(:keychain_path)
    sh(
      "security", "find-identity", "-v", "-p", "codesigning", keychain_path
    ).lines.find { |line| line.include?("Apple Distribution") }
  end

  private_lane :ensure_distribution_p12_cache do |options|
    p12_path = options.fetch(:p12_path)
    p12_password = options.fetch(:p12_password)
    keychain_path = options.fetch(:keychain_path)

    unless File.exist?(p12_path)
      identity_line = distribution_identity_in_keychain(keychain_path: keychain_path)
      unless identity_line.nil?
        UI.message("Exporting Apple Distribution identity from CI keychain into signing cache")
        export_distribution_p12(
          output_path: p12_path,
          password: p12_password,
          keychain_path: keychain_path
        )
      end
    end
  end

  private_lane :revoke_orphaned_distribution_certs do
    ensure_connect_api_token

    distribution_types = %w[
      IOS_DISTRIBUTION
      DISTRIBUTION
    ]

    revoked = 0
    distribution_types.each do |certificate_type|
      Spaceship::ConnectAPI::Certificate.all(
        filter: { certificateType: certificate_type }
      ).each do |certificate|
        UI.important(
          "Revoking orphaned Distribution certificate #{certificate.id} " \
          "(#{certificate.display_name || certificate.name})"
        )
        certificate.delete!
        revoked += 1
      end
    end

    UI.message("Revoked #{revoked} Distribution certificate(s) from App Store Connect") if revoked.positive?
  end

  private_lane :create_and_cache_distribution_cert do |options|
    api_key = options.fetch(:api_key)
    keychain_path = options.fetch(:keychain_path)
    keychain_password = options.fetch(:keychain_password)
    p12_path = options.fetch(:p12_path)
    p12_password = options.fetch(:p12_password)

    revoke_orphaned_distribution_certs

    begin
      cert(
        api_key: api_key,
        development: false,
        force: false,
        keychain_path: keychain_path,
        keychain_password: keychain_password
      )
    rescue StandardError => error
      quota_error = error.message.include?("maximum number of available Distribution certificates")
      raise error unless quota_error

      UI.important("Distribution cert quota still full — revoking portal certs and retrying once")
      revoke_orphaned_distribution_certs
      cert(
        api_key: api_key,
        development: false,
        force: false,
        keychain_path: keychain_path,
        keychain_password: keychain_password
      )
    end

    export_distribution_p12(
      output_path: p12_path,
      password: p12_password,
      keychain_path: keychain_path
    )
    UI.success("Cached new distribution certificate for future CI runs")
  end

  private_lane :install_api_signing do |options|
    api_key = options[:api_key]
    keychain_path, keychain_password = ci_keychain_credentials
    p12_path = File.join(SIGNING_CACHE_DIR, "distribution.p12")
    profile_cache_path = File.join(SIGNING_CACHE_DIR, "profile.mobileprovision")
    p12_password = signing_cache_password

    FileUtils.mkdir_p(SIGNING_CACHE_DIR)

    if File.exist?(p12_path)
      UI.message("Reusing cached distribution certificate from #{p12_path}")
      import_cached_distribution_p12(
        p12_path: p12_path,
        p12_password: p12_password,
        keychain_path: keychain_path,
        keychain_password: keychain_password
      )
    else
      ensure_distribution_p12_cache(
        p12_path: p12_path,
        p12_password: p12_password,
        keychain_path: keychain_path
      )

      if File.exist?(p12_path)
        UI.message("Reusing distribution certificate exported into signing cache")
        import_cached_distribution_p12(
          p12_path: p12_path,
          p12_password: p12_password,
          keychain_path: keychain_path,
          keychain_password: keychain_password
        )
      else
        decision = SigningDecision.resolve(
          p12_exists: false,
          allow_create: ENV["ALLOW_CREATE_DISTRIBUTION_CERT"]
        )
        case decision
        when :create
          UI.important("ALLOW_CREATE_DISTRIBUTION_CERT=true — creating a new Distribution certificate")
          create_and_cache_distribution_cert(
            api_key: api_key,
            keychain_path: keychain_path,
            keychain_password: keychain_password,
            p12_path: p12_path,
            p12_password: p12_password
          )
        when :controlled_error
          UI.user_error!(SigningDecision.controlled_error_message)
        else
          UI.user_error!("Unexpected signing decision: #{decision}")
        end
      end
    end

    profile_name = nil
    if File.exist?(profile_cache_path)
      profile_plist_path = File.join(SIGNING_CACHE_DIR, "profile.plist")
      sh("security", "cms", "-D", "-i", profile_cache_path, "-o", profile_plist_path)
      profile_name = sh("/usr/libexec/PlistBuddy", "-c", "Print :Name", profile_plist_path).strip
      profile_uuid = sh("/usr/libexec/PlistBuddy", "-c", "Print :UUID", profile_plist_path).strip
      profiles_dir = File.expand_path("~/Library/MobileDevice/Provisioning Profiles")
      FileUtils.mkdir_p(profiles_dir)
      FileUtils.cp(
        profile_cache_path,
        File.join(profiles_dir, "#{profile_uuid}.mobileprovision")
      )
      FileUtils.rm_f(profile_plist_path)
      UI.message("Reusing cached provisioning profile: #{profile_name}")
    end

    if profile_name.nil? || profile_name.empty?
      sigh(
        api_key: api_key,
        app_identifier: BUNDLE_IDENTIFIER,
        force: false
      )

      downloaded_profile = lane_context[SharedValues::SIGH_PROFILE_PATH]
      profile_name = lane_context[SharedValues::SIGH_NAME]
      FileUtils.cp(downloaded_profile, profile_cache_path)
    end

    apply_manual_signing(profile_name: profile_name)
    profile_name
  end

  private_lane :ensure_asc_version do |options|
    marketing_version = options.fetch(:marketing_version)
    if marketing_version.to_s.strip.empty?
      UI.user_error!(
        "Cannot ensure App Store Connect version: marketing_version is empty. " \
        "Check MARKETING_VERSION in #{XCODEPROJ} (target: #{APP_TARGET})."
      )
    end

    ensure_connect_api_token

    app = Spaceship::ConnectAPI::App.find(BUNDLE_IDENTIFIER)
    changed = app.ensure_version!(
      marketing_version,
      platform: Spaceship::ConnectAPI::Platform::IOS
    )

    if changed
      UI.success("Created App Store Connect version train #{marketing_version}")
    else
      UI.message("App Store Connect version train #{marketing_version} is ready")
    end
  end

  private_lane :current_marketing_version do
    version = read_project_marketing_version
    UI.message("Project marketing version: #{version}")
    version
  end

  private_lane :release_marketing_version do
    override = ENV["MARKETING_VERSION"]&.strip
    if override.nil? || override.empty?
      bumped = bump_patch_version(read_project_marketing_version)
      UI.message("Release marketing version (bumped): #{bumped}")
      bumped
    else
      UI.message("Release marketing version (override): #{override}")
      override
    end
  end

  private_lane :next_build_number do |options|
    api_key = options[:api_key]
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: BUNDLE_IDENTIFIER,
      initial_build_number: 0
    )
    latest + 1
  end

  private_lane :prepare_version_numbers do |options|
    api_key = options.fetch(:api_key)
    bump_version = options.fetch(:bump_version, false)

    marketing_version = bump_version ? release_marketing_version : current_marketing_version
    if marketing_version.to_s.strip.empty?
      UI.user_error!(
        "Marketing version is empty after reading #{XCODEPROJ} (target: #{APP_TARGET})."
      )
    end

    build_number = next_build_number(api_key: api_key).to_s

    UI.message("Using marketing version #{marketing_version} (build #{build_number})")
    ensure_asc_version(marketing_version: marketing_version)

    increment_version_number(
      version_number: marketing_version,
      xcodeproj: XCODEPROJ,
      target: APP_TARGET
    )

    increment_build_number(
      build_number: build_number,
      xcodeproj: XCODEPROJ,
      target: APP_TARGET
    )

    {
      marketing_version: marketing_version,
      build_number: build_number
    }
  end

  private_lane :build_and_upload do |options|
    api_key = options.fetch(:api_key)
    profile_name = options.fetch(:profile_name)
    marketing_version = options.fetch(:marketing_version)
    build_number = options.fetch(:build_number)

    xcode_auth_args = [
      "MARKETING_VERSION=#{marketing_version}",
      "CURRENT_PROJECT_VERSION=#{build_number}"
    ].join(" ")

    build_options = {
      scheme: "gumimap-v2",
      project: XCODEPROJ,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "gumimap-v2.ipa",
      include_bitcode: false,
      xcargs: xcode_auth_args
    }

    build_options[:export_options] = {
      method: "app-store",
      signingStyle: "manual",
      teamID: TEAM_ID,
      provisioningProfiles: {
        BUNDLE_IDENTIFIER => profile_name
      }
    }

    build_app(build_options)

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end

  desc "Emit controlled signing error when cache miss and bootstrap is disabled (contract check)"
  lane :signing_controlled_error_check do
    decision = SigningDecision.resolve(
      p12_exists: false,
      allow_create: ENV.fetch("ALLOW_CREATE_DISTRIBUTION_CERT", "false")
    )
    unless decision == :controlled_error
      UI.user_error!("Expected controlled_error decision, got #{decision}")
    end
    UI.user_error!(SigningDecision.controlled_error_message)
  end

  desc "Build and upload a TestFlight build (marketing version unchanged, build number +1)"
  lane :beta do
    api_key = asc_api_key
    prepare_app_secrets

    profile_name = install_api_signing(api_key: api_key)
    versions = prepare_version_numbers(api_key: api_key, bump_version: false)

    build_and_upload(
      api_key: api_key,
      profile_name: profile_name,
      marketing_version: versions[:marketing_version],
      build_number: versions[:build_number]
    )
  end

  desc "Bump marketing version and upload an App Store release build to TestFlight"
  lane :release do
    api_key = asc_api_key
    prepare_app_secrets

    profile_name = install_api_signing(api_key: api_key)
    versions = prepare_version_numbers(api_key: api_key, bump_version: true)

    build_and_upload(
      api_key: api_key,
      profile_name: profile_name,
      marketing_version: versions[:marketing_version],
      build_number: versions[:build_number]
    )
  end
end

def read_project_marketing_version
  get_version_number(xcodeproj: XCODEPROJ, target: APP_TARGET)
  version = Actions.lane_context[SharedValues::VERSION_NUMBER]
  if version.to_s.strip.empty?
    version = ProjectMarketingVersion.read(XCODEPROJ, APP_TARGET)
    Actions.lane_context[SharedValues::VERSION_NUMBER] = version
  end
  version
end

def bump_patch_version(version)
  segments = version.to_s.split(".").map(&:to_i)
  segments << 0 while segments.length < 3
  segments[2] += 1
  segments.join(".")
end

def ensure_connect_api_token
  return if Spaceship::ConnectAPI.token

  Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    filepath: ENV.fetch("ASC_KEY_PATH"),
    duration: 1200,
    in_house: false
  )
end